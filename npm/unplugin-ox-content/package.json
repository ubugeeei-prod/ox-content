{
  "name": "@ox-content/unplugin",
  "version": "2.65.0",
  "description": "Universal plugin for Ox Content - Markdown processing for webpack, rollup, esbuild, vite, and more",
  "keywords": [
    "esbuild",
    "markdown",
    "ox-content",
    "rollup",
    "unplugin",
    "vite",
    "webpack"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei-prod/ox-content.git",
    "directory": "npm/unplugin-ox-content"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index2.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index2.d.mts"
    },
    "./vite": {
      "import": "./dist/vite.mjs",
      "types": "./dist/vite.d.mts"
    },
    "./webpack": {
      "import": "./dist/webpack.mjs",
      "types": "./dist/webpack.d.mts"
    },
    "./rollup": {
      "import": "./dist/rollup.mjs",
      "types": "./dist/rollup.d.mts"
    },
    "./esbuild": {
      "import": "./dist/esbuild.mjs",
      "types": "./dist/esbuild.d.mts"
    },
    "./rspack": {
      "import": "./dist/rspack.mjs",
      "types": "./dist/rspack.d.mts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@ox-content/napi": "workspace:*",
    "@rollup/pluginutils": "^5.1.4",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "esbuild": "catalog:",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-smartypants": "^3.0.2",
    "remark-toc": "^9.0.0",
    "rollup": "^4.61.1",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "webpack": "^5.107.2"
  }
}
