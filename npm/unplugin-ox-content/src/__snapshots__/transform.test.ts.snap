exports[`mdast js plugin > matches upstream unified output snapshots for real-world plugin pipelines 1`] = `
{
  "rehype-external-links": "<p><a href="https://example.com" rel="nofollow noopener" target="_blank">External</a> and <a href="/docs">Local</a></p>",
  "rehype-raw-sanitize": "<p>Safe <b>bold</b>.</p>
",
  "rehype-slug-autolink-native-mdast": "<h1 id="hello">Hello<a aria-hidden="true" tabindex="-1" href="#hello">#</a></h1>
<p>World</p>",
  "remark-directive": "<aside id="plugin-note" class="note"><p>Directive <strong>body</strong>.</p></aside>",
  "remark-frontmatter": "<h1>Body</h1>",
  "remark-gfm-smartypants-toc": "<h1>Guide</h1>
<h2>Contents</h2>
<ul>
<li><a href="#install">Install</a></li>
</ul>
<h2>Install</h2>
