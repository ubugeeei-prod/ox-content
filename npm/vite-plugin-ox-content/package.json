{
  "name": "@ox-content/vite-plugin",
  "version": "2.81.0",
  "description": "Vite plugin for Ox Content - High-performance Markdown processing with Environment API",
  "keywords": [
    "environment-api",
    "markdown",
    "ox-content",
    "ssg",
    "vite",
    "vite-plugin"
  ],
  "license": "MIT",
  "author": "ubugeeei",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei-prod/ox-content.git",
    "directory": "npm/vite-plugin-ox-content"
  },
  "bin": {
    "ox-content-migrate-vitepress": "./bin/migrate-vitepress.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    },
    "./incremental-dom": {
      "import": "./dist/incremental-dom.mjs",
      "require": "./dist/incremental-dom.cjs",
      "types": "./dist/incremental-dom.d.mts"
    },
    "./vitepress-migrate": {
      "import": "./dist/vitepress-cli.mjs",
      "types": "./dist/vitepress-cli.d.mts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "typecheck": "tsgo --noEmit",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@cspell/dict-de-de": "^4.1.2",
    "@cspell/dict-en_us": "^4.4.36",
    "@cspell/dict-fr-fr": "^2.3.2",
    "@cspell/dict-pl_pl": "^3.0.6",
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "@ox-content/napi": "workspace:*",
    "cspell-lib": "^10.0.1",
    "glob": "^13.0.6",
    "playwright": "^1.61.1",
    "puppeteer": "^25.3.0",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "rolldown": "^1.2.0",
    "shiki": "^4.3.1",
    "typescript": "catalog:",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/hast": "^3.0.4",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@vue/compiler-sfc": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.0.0",
    "vite": "catalog:",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
