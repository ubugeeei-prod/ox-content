exports[`transformMarkdown > keeps package-manager tabs disabled unless opted in 1`] = `
{
  "defaultHtml": "<p><pm>npm install -D vite</pm></p>
",
  "optInHtml": "<p><div class="ox-tabs-container"><div class="ox-tabs" data-group="0"><div class="ox-tabs-header"><input type="radio" name="ox-tabs-0" id="ox-tab-0-0" checked><label for="ox-tab-0-0">npm</label><input type="radio" name="ox-tabs-0" id="ox-tab-0-1"><label for="ox-tab-0-1">pnpm</label><input type="radio" name="ox-tabs-0" id="ox-tab-0-2"><label for="ox-tab-0-2">yarn</label><input type="radio" name="ox-tabs-0" id="ox-tab-0-3"><label for="ox-tab-0-3">bun</label></div><div class="ox-tab-panel" data-tab="0"><pre><code>npm install -D vite</code></pre></div><div class="ox-tab-panel" data-tab="1"><pre><code>pnpm add -D vite</code></pre></div><div class="ox-tab-panel" data-tab="2"><pre><code>yarn add -D vite</code></pre></div><div class="ox-tab-panel" data-tab="3"><pre><code>bun add -D vite</code></pre></div></div><noscript><div class="ox-tabs-fallback"><details open><summary>npm</summary><div class="ox-tabs-fallback-content"><pre><code>npm install -D vite</code></pre></div></details><details><summary>pnpm</summary><div class="ox-tabs-fallback-content"><pre><code>pnpm add -D vite</code></pre></div></details><details><summary>yarn</summary><div class="ox-tabs-fallback-content"><pre><code>yarn add -D vite</code></pre></div></details><details><summary>bun</summary><div class="ox-tabs-fallback-content"><pre><code>bun add -D vite</code></pre></div></details></div></noscript></div></p>
",
}
`;

exports[`transformMarkdown > preserves safe raw media tags when sanitizing 1`] = `
