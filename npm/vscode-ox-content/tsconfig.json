{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "moduleResolution": "node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node", "vscode", "mocha"]
  },
  "include": ["src/**/*.ts"],
  // Unit tests run under vitest with its own TS pipeline (esbuild). They
  // can use import-attributes and other syntax not enabled here, and they
  // import vitest globals that the mocha+vscode test config does not load.
  "exclude": ["dist", "node_modules", "src/test/unit"]
}
